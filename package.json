{
  "name": "veronica-editor",
  "version": "1.0.0",
  "description": "AI-powered code editor desktop application",
  "main": "main/index.js",
  "scripts": {
    "dev:frontend": "vite",
    "dev:electron": "electron .",
    "dev": "concurrently -k \"npm run dev:frontend\" \"npm run dev:electron\"",
    "build:frontend": "tsc && vite build",
    "build": "npm run build:frontend && electron-builder"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.6.0",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.344.0",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.11.4",
    "simple-git": "^3.32.3",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "tailwind-merge": "^2.2.1",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.35",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.veronica.editor",
    "productName": "Veronica AI Code Editor",
    "icon": "assets/icon.png",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main/**/*",
      "backend/**/*",
      "backend/.env",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      ".env"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "asarUnpack": [
      "**/*.node"
    ]
  }
}